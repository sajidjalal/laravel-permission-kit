{
    "name": "sajidjalal/laravel-permission-kit",
    "description": "A lightweight and flexible permission management kit for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "permissions",
        "roles",
        "access-control",
        "acl"
    ],
    "authors": [
        {
            "name": "Sajid Jalal",
            "email": "sajidjalal@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "SajidJalal\\PermissionKit\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "SajidJalal\\PermissionKit\\PermissionKitServiceProvider"
            ],
            "aliases": {
                "RolePermission": "SajidJalal\\PermissionKit\\Facades\\Permission"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}